{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "xiaomi-mimo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "小米 MiMo",
      "options": {
        "baseURL": "https://token-plan-sgp.xiaomimimo.com/anthropic",
        "headers": {
          "anthropic-version": "2023-06-01"
        }
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "MiMo v2.5 Pro",
          "limit": { "context": 200000, "output": 32000 }
        },
        "mimo-v2.5": {
          "name": "MiMo v2.5",
          "limit": { "context": 200000, "output": 32000 }
        },
        "mimo-v2-pro": {
          "name": "MiMo v2 Pro",
          "limit": { "context": 128000, "output": 16000 }
        },
        "mimo-v2-omni": {
          "name": "MiMo v2 Omni (多模态)",
          "limit": { "context": 128000, "output": 16000 }
        },
        "mimo-v2-flash": {
          "name": "MiMo v2 Flash (快速)",
          "limit": { "context": 128000, "output": 16000 }
        }
      }
    }
  },
  "skills": {
    "paths": ["./skills", "./plugins/superpowers/skills"]
  },
  "plugin": [
    "./plugins/plugin-manager.ts",
    "./plugins/token-stats-plugin.ts",
    "./plugins/scheduled-tasks-plugin.ts",
    "./plugins/tts-plugin.ts",
    "./plugins/doctor-plugin.ts",
    "./plugins/git-worktree-plugin.ts",
    ["./plugins/im-bridge-plugin.ts", {
      "telegram": { "bot_token": "", "chat_id": "" },
      "feishu": { "app_id": "", "app_secret": "", "chat_id": "" },
      "dingtalk": { "webhook": "" },
      "wechat": { "webhook": "", "chat_id": "" }
    }],
    "./plugins/superpowers/.opencode/plugins/superpowers.js",
    "@angdrew/opencode-hashline-plugin",
    "@tarquinen/opencode-dcp",
    "@rahadiana/opencode-ultrapress",
    "opencode-enhance-plan",
    "opencode-vibeguard",
    "opencode-stability-guard",
    "opencode-supermemory-max",
    "opencode-ultra",
    "@nano-step/ai-sandbox-wrapper",
    "oh-my-opencode",
    "opencode-eslint-formatter",
    "@xeaser/opencode-obsidian-sync"
  ],
  "mcp": {
    "computer-use": {
      "type": "local",
      "command": ["npx", "tsx", "./mcp-servers/computer-use/server.ts"],
      "enabled": true,
      "timeout": 30000,
      "environment": {
        "COMPUTER_USE_ENABLED": "true",
        "COMPUTER_USE_PERMISSION_TIER": "full"
      }
    },
    "web-search": {
      "type": "local",
      "command": ["npx", "-y", "@zhafron/mcp-web-search"],
      "enabled": true,
      "timeout": 30000
    }
  },
  "agent": {
    "memory-extractor": {
      "description": "Extracts and consolidates memory from conversation history",
      "mode": "subagent",
      "hidden": true,
      "steps": 5
    },
    "coordinator": {
      "description": "Decomposes complex tasks and delegates to specialized sub-agents",
      "mode": "subagent",
      "steps": 20
    },
    "coder": {
      "description": "Focused code implementation agent",
      "mode": "subagent",
      "steps": 30
    },
    "reviewer": {
      "description": "Code review and quality analysis agent",
      "mode": "subagent",
      "permission": {
        "edit": "deny"
      }
    }
  },
  "command": {
    "usage": {
      "description": "查看 Token 用量和费用统计",
      "template": "使用 token_usage 工具获取 Token 用量和成本统计。用户输入: $ARGUMENTS"
    },
    "reset-usage": {
      "description": "重置 Token 统计",
      "template": "使用 token_reset 工具重置 Token 统计计数器。必须先与用户确认。用户输入: $ARGUMENTS"
    },
    "cron": {
      "description": "管理定时任务",
      "template": "使用 cron_list 查看任务，cron_create 创建，cron_delete 删除，cron_toggle 启用/禁用，cron_examples 查看表达式示例。用户输入: $ARGUMENTS"
    },
    "tts": {
      "description": "文本转语音",
      "template": "使用 tts_speak 合成语音，tts_config 配置，tts_status 查看状态。用户输入: $ARGUMENTS"
    },
    "doctor": {
      "description": "系统诊断",
      "template": "使用 doctor_run 运行诊断，doctor_env 查看环境信息。用户输入: $ARGUMENTS"
    },
    "worktree": {
      "description": "Git Worktree 管理",
      "template": "使用 worktree_list 列出，worktree_create 创建，worktree_remove 移除，worktree_prune 清理。用户输入: $ARGUMENTS"
    },
    "mimo": {
      "description": "小米 MiMo 配置",
      "template": "用户想使用小米 MiMo。使用 /connect 命令选择提供商，/models 选择模型。可用: mimo-v2.5-pro, mimo-v2.5, mimo-v2-pro, mimo-v2-omni, mimo-v2-flash。用户输入: $ARGUMENTS"
    }
  },
  "experimental": {
    "mcp_timeout": 30000
  }
}
